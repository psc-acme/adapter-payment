{
    "name": "psc-acme/adapter-payment",
    "description": "Package adapter-payment for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\AdapterPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/cache": "^3.0",
        "doctrine/orm": "^3.0",
        "league/flysystem": "^3.0",
        "symfony/yaml": "^7.0",
        "spatie/laravel-permission": "^6.0",
        "webmozart/assert": "^1.0",
        "psc-acme/driver-auth": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}